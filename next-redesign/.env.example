# Supabase public client settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only settings. Never expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only travel password settings.
# TRAVEL_PASSWORD_HASH must be the SHA-256 hex digest of the shared travel password.
TRAVEL_PASSWORD_HASH=your-64-character-sha256-password-hash
TRAVEL_SESSION_SECRET=replace-with-at-least-32-random-characters
TRAVEL_SESSION_TTL_SECONDS=1209600

# Optional server-only OCR provider key.
OPENAI_API_KEY=your-openai-api-key

# Google Drive photo album integration.
# These are public browser settings, not client secrets.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_DRIVE_ALBUM_FOLDER_ID=1p33mX1C8xLeB7P8RvRgMWlFKPqdFeQww
